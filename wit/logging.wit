// OpenZax Host Logging Interface
// Provides structured logging capabilities to WASM skills

package openzax:host@1.0.0;

interface logging {
    // Log levels matching standard severity levels
    enum level {
        trace,
        debug,
        info,
        warn,
        error,
    }

    // Log a message with the specified level
    log: func(level: level, message: string);

    // Start a tracing span for structured logging
    span-start: func(name: string) -> u64;

    // End a tracing span
    span-end: func(span-id: u64);
}
