# Auto detect text files and perform LF normalization
* text=auto

# Rust source files
*.rs text eol=lf

# WASM files
*.wasm binary
*.wat text eol=lf

# WIT files
*.wit text eol=lf

# Documentation
*.md text eol=lf

# Configuration files
*.toml text eol=lf
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Shell scripts
*.sh text eol=lf
