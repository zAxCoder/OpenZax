{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "OpenZax",
  "version": "0.7.2",
  "identifier": "dev.openzax.desktop",
  "build": {
    "frontendDist": "../tauri-app/frontend"
  },
  "app": {
    "windows": [
      {
        "title": "OpenZax - Secure AI Development Assistant",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright 2026 OpenZax Team",
    "category": "DeveloperTool",
    "shortDescription": "Secure AI Development Assistant",
    "longDescription": "OpenZax is a secure AI development assistant built with Rust."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
