{
  "$schema": "https://schema.tauri.app/config/2.0",
  "productName": "OpenZax",
  "version": "0.4.0",
  "identifier": "dev.openzax.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenZax - Secure AI Development Assistant",
        "width": 1400,
        "height": 900,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [],
    "copyright": "Copyright © 2026 OpenZax Team",
    "category": "DeveloperTool",
    "shortDescription": "Secure AI Development Assistant",
    "longDescription": "OpenZax is a secure AI development assistant built with Rust, featuring WASM sandboxing and zero-trust architecture."
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
